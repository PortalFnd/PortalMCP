# Ethereum network settings
ETHEREUM_NETWORK=mainnet
# Optional: full RPC URL (Alchemy, QuickNode, self-hosted) — takes priority over
# INFURA_API_KEY / ALCHEMY_API_KEY. Use the modern g.alchemy.com domain.
# Example: https://eth-mainnet.g.alchemy.com/v2/<YOUR_KEY>
ETHEREUM_RPC_URL=
INFURA_API_KEY=your_infura_api_key_here
# Provide just the key; PortalMCP will build the modern g.alchemy.com URL.
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Wallet settings (KEEP SECURE - DO NOT COMMIT TO VERSION CONTROL)
# Only needed if you want to execute transactions directly
DEPLOYER_PRIVATE_KEY=your_private_key_here

# Anthropic Claude API (for contract generation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model for eth_generate_contract (default: claude-sonnet-4-5-20250929)
ANTHROPIC_MODEL=

# MCP Server settings
PORT=3001

# Streamable HTTP transport (npm run start:http)
MCP_HTTP_PORT=3333
MCP_HTTP_HOST=0.0.0.0
# Optional: if set, clients must send `Authorization: Bearer <token>`
MCP_HTTP_TOKEN=
# Optional: CORS origin (defaults to '*')
MCP_HTTP_CORS_ORIGIN=

# Gas price settings (optional)
GAS_PRICE_MULTIPLIER=1.1
